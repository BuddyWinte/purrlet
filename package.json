{
  "name": "purrlet",
  "version": "0.0.1",
  "description": "A lightweight, customizable, feature-rich drawbox and upload library built for React, Vue, Astro, and modern JavaScript apps.",
  "main": "./dist/purrlet.min.js",
  "module": "./dist/purrlet.mjs",
  "exports": {
    ".": {
      "require": "./dist/purrlet.min.js",
      "import": "./dist/purrlet.mjs",
      "default": "./dist/purrlet.mjs"
    },
    "./react": {
      "import": "./dist/react.mjs",
      "default": "./dist/react.mjs"
    },
    "./vue": {
      "import": "./dist/vue.mjs",
      "default": "./dist/vue.mjs"
    },
    "./astro": {
      "import": "./dist/astro.mjs",
      "default": "./dist/astro.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "dev": "rollup -c --watch",
    "build": "rollup -c",
    "prepublishOnly": "npm run build",
    "lint": "eslint ."
  },
  "keywords": [
    "upload",
    "imgbb",
    "react",
    "vue",
    "astro",
    "javascript",
    "library",
    "drawbox"
  ],
  "author": "BuddyWinte",
  "license": "MIT",
  "homepage": "https://github.com/BuddyWinte/Purrlet#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BuddyWinte/Purrlet.git"
  },
  "bugs": {
    "url": "https://github.com/BuddyWinte/Purrlet/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/BuddyWinte"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "commonjs",
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "eslint": "^10.0.0",
    "prettier": "^3.8.1",
    "rollup": "^4.57.1"
  }
}
